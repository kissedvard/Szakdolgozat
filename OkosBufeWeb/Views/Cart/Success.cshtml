@{
    ViewData["Title"] = "Sikeres Rendelés";
}

<div class="container my-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            
            <div class="mb-4">
                <i class="fa-solid fa-circle-check text-success" style="font-size: 6rem;"></i>
            </div>
            
            <h1 class="display-4 fw-bold text-dark mb-3">Rendelés rögzítve!</h1>
            <p class="lead text-muted mb-5">
                A konyha megkapta a rendelésedet. Hamarosan kész, ugorj a büféhez a szünetben!
            </p>

            <div class="card border-0 shadow-lg mb-5 rounded-4" style="background-color: #f8f9fa; border-top: 8px solid #C5A059 !important;">
                <div class="card-body p-5">
                    <h5 class="text-uppercase text-muted fw-bold mb-3">A te sorszámod:</h5>
                    <div class="display-1 fw-bolder text-dark">
                        #@ViewBag.OrderId
                    </div>
                </div>
            </div>

            <a asp-controller="Home" asp-action="Menu" class="btn btn-primary btn-lg px-5 py-3 rounded-pill fw-bold shadow-sm">
                <i class="fa-solid fa-arrow-left me-2"></i>Vissza a kínálathoz
            </a>

        </div>
    </div>
</div>