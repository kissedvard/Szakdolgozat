@model IEnumerable<OkosBufeWeb.Models.Order>

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 row-cols-xxl-4 g-4">
    @foreach (var order in Model)
    {
        <div class="col">
            <div class="card h-100 shadow border-0" style="background-color: #fffdf5; border-top: 10px solid #347c47 !important;">
                <div class="card-body p-4 d-flex flex-column">
                    
                    <div class="d-flex justify-content-between align-items-start mb-3 border-bottom pb-3">
                        <h2 class="fw-bolder m-0" style="font-size: 2.8rem;">#@order.Id</h2>
                        <span class="badge bg-danger fs-4 px-3 py-2 shadow-sm">
                            <i class="fa-regular fa-clock me-1"></i> @((DateTime.Now - order.OrderTime).Minutes) perce
                        </span>
                    </div>
                    
                    <div class="flex-grow-1">
                        <ul class="list-unstyled fw-bold text-dark mb-4" style="font-size: 2rem; line-height: 1.8;">
                            @foreach (var item in order.OrderItems)
                            {
                                <li class="mb-2">
                                    <span class="text-success me-3">@(item.Quantity)x</span>
                                    @(item.Product?.Name ?? "Ismeretlen termék")
                                </li>
                            }
                        </ul>
                    </div>
                    
                    <form asp-action="CompleteOrder" asp-route-id="@order.Id" method="post">
                        <button type="submit" class="btn btn-success w-100 fw-bold shadow mt-auto" style="font-size: 2.2rem; padding: 1.2rem;">
                            <i class="fa-solid fa-check-double me-2"></i>KÉSZ
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>