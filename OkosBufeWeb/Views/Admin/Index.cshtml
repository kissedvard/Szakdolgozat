@model IEnumerable<OkosBufeWeb.Models.Order>

@{
    ViewData["Title"] = "Beérkező Rendelések";
}

<div class="container-fluid mt-3 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
        <div>
            <h1 class="fw-bold text-dark m-0 display-6">
                <i class="fa-solid fa-bell text-danger me-2"></i>Aktív Rendelések
            </h1>
        </div>
        <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg fw-bold px-5 py-3 fs-4 shadow">
            <i class="fa-solid fa-box-open me-2"></i>Termék Adminisztráció
        </a>
    </div>

    <div id="ordersContainer">
        @await Html.PartialAsync("_OrderCards", Model)
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/kds-signalr.js" asp-append-version="true"></script>
}