@model IEnumerable<OkosBufeWeb.Models.Product>
@using Microsoft.AspNetCore.Http
@using OkosBufeWeb.Helpers
@using Microsoft.EntityFrameworkCore

@inject OkosBufeWeb.Data.ApplicationDbContext _context

@{
    ViewData["Title"] = "Főoldal - Étlap";
    var cart = Context.Session.GetObjectFromJson<List<OkosBufeWeb.Models.CartItem>>("Cart") ?? new List<OkosBufeWeb.Models.CartItem>();

    var favoriteOrder = await _context.Orders
    .Include(o => o.OrderItems)
    .ThenInclude(i => i.Product)
    .FirstOrDefaultAsync(o => o.isFavorite);
}

<div class="text-center mb-5">
    <h1 class="display-4 text-primary fw-bold">Rendeld meg kedvenceidet!</h1>
    <p class="lead">Válaszd ki a kedvenceidet, és rendeld meg sorban állás nélkül.</p>
</div>

@if (favoriteOrder != null)
{
    <div class="row justify-content-center mb-5">
        <div class="col-md-10 col-lg-8">
            <div class="card border-0 shadow-sm rounded-4" style="background-color: #f7f9f6; border: 2px solid #3e6d42 !important;">
                <div class="card-body p-4 d-flex flex-column flex-md-row justify-content-between align-items-center">
                    
                    <div class="mb-3 mb-md-0 text-center text-md-start">
                        <h4 class="fw-bold mb-1" style="color: #3e6d42;">
                            <i class="fa-solid fa-star text-warning me-2"></i>A Szokásos Menüd
                        </h4>
                        <p class="text-muted small mb-2">Egyetlen kattintással a kosaradba teheted a kedvenceidet!</p>
                        
                        <div class="fw-bold text-dark">
                            @foreach (var item in favoriteOrder.OrderItems)
                            {
                                <span>@item.Quantity x @(item.Product?.Name ?? "Ismeretlen termék") @(item != favoriteOrder.OrderItems.Last() ? " + " : "")</span>
                            }
                        </div>
                    </div>

                    <form asp-controller="Cart" asp-action="ReorderUsual" method="post" class="flex-shrink-0 mt-3 mt-md-0">
                        <input type="hidden" name="orderId" value="@favoriteOrder.Id" />
                        <button type="submit" class="btn text-white rounded-pill fw-bold px-4 py-2 shadow-sm" style="background-color: #3e6d42; transition: transform 0.2s;">
                            <i class="fa-solid fa-bolt me-2"></i> Kérem a szokásosat
                        </button>
                    </form>

                </div>
            </div>
        </div>
    </div>
}

@* Kategória szerint csoportosítva *@
@foreach (var categoryGroup in Model.GroupBy(p => p.Category))
{
    <h2 class="fw-bold text-dark mt-5 mb-4 border-bottom pb-2">
        @categoryGroup.Key
    </h2>

    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 row-cols-xxl-4 g-4">
        
        @foreach (var item in categoryGroup)
        {
            // EZT A RÉSZT KÜLDTED TE – TELJESEN ÉRINTETLENÜL HAGYVA:
            var cartItem = cart.FirstOrDefault(c => c.ProductId == item.Id);
            int quantityInCart = cartItem != null ? cartItem.Quantity : 0;

            <div class="col">
                <div class="card h-100 shadow-sm border-0" style="min-height: 280px">
                    <div class="card-body text-center">
                        <h5 class="card-title fw-bold">@item.Name</h5>
                        <h6 class="text-success fw-bold mb-3">@item.Price Ft</h6>
                        <p class="card-text text-muted small">@item.Description</p>
                    </div>
                    
                    <div class="card-footer bg-transparent border-0 text-center pb-3">
                        @if (quantityInCart == 0)
                        {
                            <a asp-controller="Cart" asp-action="Add" asp-route-id="@item.Id" class="btn btn-primary w-100 rounded-pill fw-bold">
                                <i class="bi bi-cart-plus"></i> Kosárba teszem
                            </a>
                        }
                        else
                        {
                            <div class="btn btn-primary w-100 rounded-pill d-flex justify-content-between align-items-center px-4 user-select-none">
                                
                                <a href="javascript:void(0)" onclick="updateQuantity(@item.Id, 'decrease')" class="text-white text-decoration-none fw-bold fs-5">
                                    <i class="fa-solid fa-minus"></i>
                                </a>
                                
                                <span class="text-white fw-bold pointer-event-none" id="qty-@item.Id">
                                    @quantityInCart db
                                </span>
                                
                                <a href="javascript:void(0)" onclick="updateQuantity(@item.Id, 'add')" class="text-white text-decoration-none fw-bold fs-5">
                                    <i class="fa-solid fa-plus"></i>
                                </a>

                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
</div>

@if (!Model.Any())
{
    <div class="alert alert-warning text-center mt-4">
        Jelenleg nincs elérhető termék a büfében. Kérjük, nézz vissza később!
    </div>
}