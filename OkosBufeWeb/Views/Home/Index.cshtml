@{
    ViewData["Title"] = "Üdvözlünk";
}


<!-- 1. SZEKCIÓ: Hero (Kiemelt fejléc) -->
<div class="container my-5">
    <div class="row p-5 pb-0 pe-lg-0 pt-lg-5 align-items-center hero-bg shadow-sm">
        <div class="col-lg-7 p-3 p-lg-5 pt-lg-3 text-center text-lg-start">
            <h1 class="display-4 fw-bold lh-1 mb-3 text-primary">Rendelj okosan,<br /> ne állj sorba!</h1>
            <p class="lead mb-4">Az ETO Okos Büfé elhozza neked a kényelmet. Állítsd össze a rendelésedet a telefonodon még az óra alatt, és vedd át frissen a szünetben, várakozás nélkül.</p>
            <div class="d-grid gap-2 d-md-flex justify-content-md-start mb-4 mb-lg-3">
                <!-- Ez a gomb viszi át a felhasználót az új étlap (Menu) oldalra! -->
                <a asp-controller="Home" asp-action="Menu" class="btn btn-primary btn-lg px-4 me-md-2 fw-bold">Éhes vagyok, rendelek!</a>
                <a href="#how-it-works" class="btn btn-outline-secondary btn-lg px-4">Hogyan működik?</a>
            </div>
        </div>
        <div class="col-lg-4 offset-lg-1 p-0 overflow-hidden text-center">
            <!-- Ide tehetsz majd egy szép illusztrációt! -->
            <i class="bi bi-phone text-primary" style="font-size: 15rem; opacity: 0.8;"></i>
        </div>
    </div>
</div>

@if (!User.Identity!.IsAuthenticated)
{
    <div class="container my-5 py-5 border-top">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Miért éri meg regisztrálni?</h2>
            <p class="text-muted">Csatlakozz a rendszerhez, és felejtsd el a sorban állást!</p>
        </div>

        <div class="row g-4 text-center mb-5">
            <div class="col-md-4">
                <div class="p-4 bg-white rounded-4 h-100 shadow-sm border border-light" style="transition: transform 0.3s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                    <i class="fa-solid fa-mobile-screen-button fa-3x mb-3" style="color: #347c47;"></i>
                    <h4 class="fw-bold">Rendelj mobilon</h4>
                    <p class="text-muted mb-0">Állítsd össze a kedvenc szendvicsedet még a tanórán, pár kattintással.</p>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="p-4 bg-white rounded-4 h-100 shadow-sm border border-light" style="transition: transform 0.3s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                    <i class="fa-solid fa-stopwatch fa-3x mb-3" style="color: #347c47;"></i>
                    <h4 class="fw-bold">Nincs sorban állás</h4>
                    <p class="text-muted mb-0">Csak besétálsz a szünetben, és azonnal átveszed a névre szóló csomagodat.</p>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="p-4 bg-white rounded-4 h-100 shadow-sm border border-light" style="transition: transform 0.3s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                    <i class="fa-solid fa-burger fa-3x mb-3" style="color: #347c47;"></i>
                    <h4 class="fw-bold">Garantáltan friss</h4>
                    <p class="text-muted mb-0">A rendelésed alapján frissen készítjük el, pontosan arra a szünetre.</p>
                </div>
            </div>
        </div>

        <div class="text-center mt-4">
            <h5 class="mb-4 text-muted">Készen állsz az első rendelésre?</h5>
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg px-5 py-3 fw-bold rounded-pill shadow-sm">
                Regisztrálok a rendszerbe!
            </a>
        </div>
    </div>
}
else
{
    <div class="text-center mt-5 pt-4">
        <a asp-controller="Home" asp-action="Menu" class="btn btn-primary btn-lg px-5 py-3 fw-bold rounded-pill shadow-sm">
            Irány a rendelés! <i class="fa-solid fa-arrow-right ms-2"></i>
        </a>
    </div>
}


<!-- 3. SZEKCIÓ: Gyakori Kérdések (Interaktív Accordion) -->
<div class="container mb-5 w-75">
    <h3 class="text-center mb-4">Gyakori Kérdések</h3>
    <div class="accordion shadow-sm" id="faqAccordion">
        <div class="accordion-item">
            <h2 class="accordion-header" id="headingOne">
                <button class="accordion-button fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                    Mikor tudom átvenni a rendelésemet?
                </button>
            </h2>
            <div id="collapseOne" class="accordion-collapse collapse show" aria-labelledby="headingOne" data-bs-parent="#faqAccordion">
                <div class="accordion-body">
                    A megrendelt termékeket a következő óraközi szünetben, az erre kijelölt "Gyorssávban" (Fast Track) veheted át a büfénél.
                </div>
            </div>
        </div>
        <div class="accordion-item">
            <h2 class="accordion-header" id="headingTwo">
                <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                    Módosíthatom a leadott rendelést?
                </button>
            </h2>
            <div id="collapseTwo" class="accordion-collapse collapse" aria-labelledby="headingTwo" data-bs-parent="#faqAccordion">
                <div class="accordion-body">
                    A rendelés leadása után a rendszer egyből a konyhára küldi a blokkot, így utólagos módosításra a felületen már nincs lehetőség.
                </div>
            </div>
        </div>
    </div>
</div>