@model IEnumerable<OkosBufeWeb.Models.Product>

@{
    ViewData["Title"] = "Kínálat";
}

<div class="container mt-4">
    <h2 class="mb-4 text-primary">Büfé Kínálata</h2>

    <a asp-action="Create" class="btn btn-success mb-3">+ Új termék hozzáadása</a>

    <div class="table-responsive">
        <table class="table table-striped table-hover shadow-sm rounded">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Név</th>
                    <th>Leírás</th>
                    <th>Ár</th>
                    <th>Státusz</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td class="fw-bold">@item.Name</td>
                        <td>@item.Description</td>
                        <td>@item.Price Ft</td>
                        <td>
                            @if (item.IsAvailable)
                            {
                                <span class="badge bg-success">Rendelhető</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Elfogyott</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>