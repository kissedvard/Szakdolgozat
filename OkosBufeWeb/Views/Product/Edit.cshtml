@model OkosBufeWeb.Models.Product

@{
    ViewData["Title"] = "Termék Szerkesztése";
}

<div class="container mt-4">
    <h2 class="text-primary mb-4">Termék szerkesztése</h2>
    
    <div class="row">
        <div class="col-md-6 shadow-sm p-4 bg-light rounded">
            <form asp-action="Edit" method="post">
                <input asp-for="Id" hidden />
                
                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold">Termék neve</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Price" class="form-label fw-bold">Ár (Ft)</label>
                    <input asp-for="Price" class="form-control" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-bold">Leírás</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="IsAvailable" class="form-check-input" />
                    <label asp-for="IsAvailable" class="form-check-label">Azonnal rendelhető</label>
                </div>

                <button type="submit" class="btn btn-primary w-100 mb-2">Változtatások mentése</button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100">Mégse</a>
                
            </form>
        </div>
    </div>
</div>